{
  "name": "agent",
  "version": "0.1.0",
  "description": "macOS Personal AI Assistant",
  "main": "out/main/index.js",
  "author": {
    "name": "Agent"
  },
  "homepage": ".",
  "scripts": {
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "rebuild": "electron-rebuild -f -w better-sqlite3,keytar",
    "postinstall": "electron-rebuild -f -w better-sqlite3,keytar",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.20.9",
    "better-sqlite3": "12.8.0",
    "chrono-node": "2.7.6",
    "electron-updater": "6.1.8",
    "keytar": "7.9.0",
    "ky": "1.3.0",
    "mathjs": "12.4.2",
    "pino": "9.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "9.0.1",
    "remark-gfm": "4.0.0",
    "uuid": "9.0.1",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/mathjs": "9.4.2",
    "@types/node": "20.12.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/uuid": "9.0.8",
    "@vitejs/plugin-react": "4.3.0",
    "autoprefixer": "10.4.19",
    "electron": "^33.4.11",
    "electron-builder": "24.13.3",
    "electron-rebuild": "3.2.9",
    "electron-vite": "5.0.0",
    "eslint": "8.57.0",
    "pino-pretty": "13.0.0",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.3",
    "typescript": "5.4.5",
    "vite": "6.3.3",
    "vitest": "1.6.0"
  },
  "build": {
    "appId": "com.agent.app",
    "productName": "Agent",
    "copyright": "Copyright © 2024",
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "icon": "resources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "publish": {
      "provider": "github"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
